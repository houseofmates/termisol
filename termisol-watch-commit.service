[Unit]
Description=Termisol File Watch and Auto-Commit Service
After=network.target

[Service]
Type=simple
ExecStart=/path/to/termisol/scripts/watch_and_commit.sh
User=your_username
WorkingDirectory=/path/to/termisol
Environment=PATH=/usr/local/bin:/usr/bin:/bin
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
