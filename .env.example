# NVIDIA API Keys for Termisol AI Integration
# Copy this file to .env and add your actual API keys
# Format: NVIDIA_API_KEY_1=your_key_here through NVIDIA_API_KEY_24=your_key_here

# DeepL API Key for translate feature
DEEPL_API_KEY=

# NVIDIA API Keys (24 keys for round-robin rotation)
NVIDIA_API_KEY_1=
NVIDIA_API_KEY_2=
NVIDIA_API_KEY_3=
NVIDIA_API_KEY_4=
NVIDIA_API_KEY_5=
NVIDIA_API_KEY_6=
NVIDIA_API_KEY_7=
NVIDIA_API_KEY_8=
NVIDIA_API_KEY_9=
NVIDIA_API_KEY_10=
NVIDIA_API_KEY_11=
NVIDIA_API_KEY_12=
NVIDIA_API_KEY_13=
NVIDIA_API_KEY_14=
NVIDIA_API_KEY_15=
NVIDIA_API_KEY_16=
NVIDIA_API_KEY_17=
NVIDIA_API_KEY_18=
NVIDIA_API_KEY_19=
NVIDIA_API_KEY_20=
NVIDIA_API_KEY_21=
NVIDIA_API_KEY_22=
NVIDIA_API_KEY_23=
NVIDIA_API_KEY_24=

# N8N API Key (Self-hosted workflow automation)
# Get your API key from your N8N instance
N8N_API_KEY=

# Nextcloud Configuration (Self-hosted cloud storage)
# Configure your Nextcloud instance URL
NEXTCLOUD_BASE_URL=https://your-nextcloud-instance.com
NEXTCLOUD_USERNAME=your_username
NEXTCLOUD_API_KEY=

# Docker Stack Configuration
# Path to your main docker-compose stack
DOCKER_STACK_PATH=/path/to/your/docker/stack

# Personal Preferences
PERSONAL_NAME=your_name
DEFAULT_PROJECT_SERVER=.233
BACKUP_SERVER=.250

# Hardware Configuration
MAIN_GPU_MODEL=RTX_3080
SECONDARY_GPU_MODEL=RTX_2070
MAIN_GPU_MEMORY=10240
SECONDARY_GPU_MEMORY=8192

# Performance Profiles
ENABLE_ADAPTIVE_PERFORMANCE=true
ENABLE_AI_OPTIMIZATION=true
ENABLE_SMART_CLEANUP=true
CLEANUP_SCHEDULE=daily

# Amnesia Protection
ENABLE_AMNESIA_PROTECTION=true
BACKUP_INTERVAL_MINUTES=15
MAX_BACKUP_FILES=100

# Integration Settings
ENABLE_HERMES_INTEGRATION=true
ENABLE_N8N_INTEGRATION=true
ENABLE_NEXTCLOUD_INTEGRATION=true
ENABLE_DOCKER_INTEGRATION=true

# AI Model Preferences
PRIMARY_AI_MODEL=deepseek-ai/deepseek-v4-pro
SECONDARY_AI_MODEL=deepseek-ai/deepseek-v4-flash
MULTIMODAL_MODEL=moonshotai/kimi-k2.6
OPTIMIZATION_MODEL=z-ai/glm-5.1
RESOURCE_MODEL=minimaxai/minimax-m2.7

# VirusTotal API for Malware Detection
# Get your API key from https://www.virustotal.com/
VIRUSTOTAL_API_KEY=

# Network Configuration
# Replace with your actual network configuration
UBUNTU_250_HOST=192.168.4.250
POPOS_233_HOST=192.168.4.233
NOCOBASE_HOST=192.168.1.233
NOCOBASE_PORT=5432
NOCOBASE_DATABASE=nocobase
MEMSTER_HOST=192.168.1.250
MEMSTER_PORT=5432
MEMSTER_DATABASE=memster

# Server URLs
# Replace with your actual server URLs
HERMES_SERVER_URL=ws://localhost:8080
NEXTCLOUD_BASE_URL=https://cloud.houseofmates.space
N8N_BASE_URL=https://n8n.houseofmates.space

# Docker Configuration
# Replace with your actual Docker stack path
DOCKER_STACK_PATH=/home/house/Documents/docker/main-stack

# Personal Configuration
# Replace with your actual personal settings
PERSONAL_NAME=house
DEFAULT_PROJECT_SERVER=.233
BACKUP_SERVER=.250

# SSH Configuration
# Replace with your actual SSH settings
SSH_USER=house
SSH_KEY_PATH=~/.ssh/id_rsa

# Repository Configuration
# Replace with your actual repository path
TERMISOL_REPO_DIR=/path/to/your/termisol
